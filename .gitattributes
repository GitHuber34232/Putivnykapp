#
# https://help.github.com/articles/dealing-with-line-endings/
#
# Linux start script should use lf
/gradlew        text eol=lf

# Unix shell scripts and CI configs should stay LF on macOS/Linux runners
*.sh            text eol=lf
*.yml           text eol=lf
Makefile        text eol=lf
*.md            text eol=lf

# These are Windows script files and should use crlf
*.bat           text eol=crlf
*.ps1           text eol=crlf

